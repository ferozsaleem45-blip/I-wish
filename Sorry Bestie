<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sorry Aira ❤️</title>
    <style>
        /* ===== ALL STYLES ===== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
            overflow-x: hidden;
            margin: 0;
        }

        #fireworks {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 0;
        }

        .container {
            background: rgba(255, 255, 255, 0.95);
            padding: 40px;
            border-radius: 30px;
            max-width: 600px;
            width: 100%;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            position: relative;
            z-index: 1;
            animation: fadeIn 0.5s ease;
            max-height: 90vh;
            overflow-y: auto;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: scale(0.9); }
            to { opacity: 1; transform: scale(1); }
        }

        h1, h2 {
            color: #764ba2;
            margin-bottom: 20px;
            text-align: center;
        }

        .page {
            display: none;
        }

        .page.active {
            display: block;
            animation: fadeIn 0.5s ease;
        }

        .typing {
            overflow: hidden;
            border-right: 3px solid #764ba2;
            white-space: nowrap;
            animation: typing 3s steps(30) 1s forwards, blink 0.5s step-end infinite;
            width: 0;
        }

        @keyframes typing {
            from { width: 0; }
            to { width: 100%; }
        }

        @keyframes blink {
            50% { border-color: transparent; }
        }

        .apology-card {
            background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
            padding: 30px;
            border-radius: 20px;
            color: white;
            margin: 20px 0;
            box-shadow: 0 10px 30px rgba(245, 87, 108, 0.3);
        }

        .apology-letter, .letter-text {
            background: white;
            padding: 30px;
            border-radius: 20px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.1);
            margin: 20px 0;
            line-height: 1.8;
        }

        .heart-emoji {
            font-size: 2em;
            text-align: center;
            animation: pulse 1.5s ease-in-out infinite;
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.2); }
        }

        .next-btn {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            padding: 15px 40px;
            border-radius: 50px;
            font-size: 1.1em;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-top: 20px;
            width: 100%;
        }

        .next-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 30px rgba(102, 126, 234, 0.4);
        }

        #musicToggle {
            position: fixed;
            top: 20px;
            right: 20px;
            background: rgba(255,255,255,0.9);
            border: none;
            padding: 10px 20px;
            border-radius: 50px;
            cursor: pointer;
            z-index: 999;
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
            font-size: 14px;
        }

        .slideshow-container {
            position: relative;
            margin: 20px 0;
        }

        .slide {
            display: none;
            text-align: center;
        }

        .slide img {
            width: 100%;
            border-radius: 20px;
            height: 300px;
            object-fit: cover;
        }

        .prev, .next-slide {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            background: rgba(255,255,255,0.8);
            border: none;
            padding: 10px 15px;
            cursor: pointer;
            border-radius: 50%;
            font-size: 1.5em;
            z-index: 10;
        }

        .prev { left: 10px; }
        .next-slide { right: 10px; }

        .forgive-box {
            display: flex;
            gap: 20px;
            justify-content: center;
            margin: 30px 0;
            flex-wrap: wrap;
        }

        #yesBtn {
            background: linear-gradient(135deg, #00b09b, #96c93d);
            color: white;
            border: none;
            padding: 15px 40px;
            border-radius: 50px;
            font-size: 1.2em;
            cursor: pointer;
            transition: transform 0.3s;
        }

        #yesBtn:hover {
            transform: scale(1.1);
        }

        #noBtn {
            background: linear-gradient(135deg, #f093fb, #f5576c);
            color: white;
            border: none;
            padding: 15px 40px;
            border-radius: 50px;
            font-size: 1.2em;
            cursor: pointer;
            transition: all 0.3s;
        }

        .letter {
            background: linear-gradient(135deg, #f5af19, #f12711);
            padding: 40px;
            border-radius: 20px;
            text-align: center;
            cursor: pointer;
            font-size: 1.5em;
            color: white;
            margin: 20px 0;
        }

        #typingContainer {
            background: white;
            padding: 30px;
            border-radius: 20px;
            min-height: 100px;
            margin: 20px 0;
        }

        #typingText {
            display: inline;
            font-size: 1.2em;
        }

        .cursor {
            display: inline-block;
            animation: blink 0.7s infinite;
        }

        .promise-card {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin: 20px 0;
        }

        .promise {
            background: white;
            padding: 20px;
            border-radius: 15px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }

        .promise ul {
            list-style: none;
            padding: 0;
        }

        .promise li {
            padding: 8px 0;
            border-bottom: 1px solid #eee;
        }

        .final-page .big-text {
            font-size: 2.5em;
            color: #f5576c;
        }

        .final-message {
            text-align: center;
            font-size: 1.3em;
            line-height: 2;
        }

        .big-emoji {
            font-size: 3em;
        }

        #confetti-container {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 1000;
        }

        .confetti-piece {
            position: absolute;
            width: 10px;
            height: 10px;
            animation: confettiFall linear forwards;
        }

        @keyframes confettiFall {
            0% { transform: translateY(-10vh) rotate(0deg); opacity: 1; }
            100% { transform: translateY(110vh) rotate(720deg); opacity: 0; }
        }

        .highlight {
            color: #f5576c;
            font-weight: bold;
            font-size: 1.2em;
        }

        .signature {
            text-align: right;
            font-style: italic;
            margin-top: 20px;
        }

        /* Mobile Responsive */
        @media (max-width: 768px) {
            .container {
                padding: 20px;
            }
            
            .promise-card {
                grid-template-columns: 1fr;
            }
            
            .forgive-box {
                flex-direction: column;
            }
            
            .final-page .big-text {
                font-size: 1.8em;
            }
            
            #musicToggle {
                top: 10px;
                right: 10px;
                padding: 8px 15px;
                font-size: 12px;
            }

            .slide img {
                height: 200px;
            }
        }

        .confetti-piece:nth-child(6n+1) { background: #f5576c; }
        .confetti-piece:nth-child(6n+2) { background: #4facfe; }
        .confetti-piece:nth-child(6n+3) { background: #43e97b; }
        .confetti-piece:nth-child(6n+4) { background: #fa709a; }
        .confetti-piece:nth-child(6n+5) { background: #fee140; }
        .confetti-piece:nth-child(6n+6) { background: #a18cd1; }

        .page-indicator {
            text-align: center;
            color: #999;
            font-size: 14px;
            margin-top: 15px;
        }

        .page-indicator span {
            display: inline-block;
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: #ddd;
            margin: 0 5px;
            transition: all 0.3s;
        }

        .page-indicator span.active-dot {
            background: #764ba2;
            transform: scale(1.2);
        }
    </style>
</head>
